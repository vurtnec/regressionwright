{
  "name": "@regressionwright/core",
  "version": "0.1.0",
  "description": "RegressionWright core for deterministic, stage-based E2E regression pipelines with AI oversight.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "keywords": [
    "e2e",
    "regression",
    "playwright",
    "appium",
    "ios-testing",
    "mobile-testing",
    "test-harness",
    "automation",
    "ai-assisted-testing",
    "end-to-end-testing",
    "qa-automation",
    "test-pipeline",
    "dynamic-test-data",
    "typescript"
  ],
  "homepage": "https://github.com/vurtnec/regressionwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vurtnec/regressionwright.git"
  },
  "bugs": {
    "url": "https://github.com/vurtnec/regressionwright/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "bin": {
    "create-regressionwright": "./bin/create-regressionwright.mjs",
    "regressionwright": "./bin/regressionwright.mjs",
    "harness": "./bin/regressionwright.mjs"
  },
  "exports": {
    "./browser-profile.mjs": "./src/core/browser-profile.mjs",
    "./cli-options.mjs": "./src/core/cli-options.mjs",
    "./env-vars.mjs": "./src/core/env-vars.mjs",
    "./evidence.mjs": "./src/core/evidence.mjs",
    "./paths.mjs": "./src/core/paths.mjs",
    "./performance-monitor.mjs": "./src/core/performance-monitor.mjs",
    "./project-adapter.mjs": "./src/core/project-adapter.mjs",
    "./run-context.mjs": "./src/core/run-context.mjs",
    "./run-data.mjs": "./src/core/run-data.mjs",
    "./schema.mjs": "./src/core/schema.mjs",
    "./stage-error.mjs": "./src/core/stage-error.mjs",
    "./stage-input.mjs": "./src/core/stage-input.mjs",
    "./stage.mjs": "./src/core/stage.mjs",
    "./env.js": "./src/core/env.ts",
    "./evidence.js": "./src/core/evidence.ts",
    "./run-context.js": "./src/core/run-context.ts",
    "./stage-input.js": "./src/core/stage-input.ts",
    "./stage.js": "./src/core/stage.ts",
    "./integrations/mail/gmail.js": "./src/integrations/mail/gmail.ts",
    "./tests/harness/pipeline-runner.spec.mjs": "./tests/harness/pipeline-runner.spec.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "scripts/harness.mjs",
    "scripts/appium-runner.mjs",
    "scripts/check-package.mjs",
    "scripts/open-browser-profile.mjs",
    "scripts/refresh-auth.mjs",
    "src/core/",
    "src/integrations/",
    "tests/harness/",
    "skills/regressionwright/",
    "templates/",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/framework.md",
    "docs/regressionwright-architecture.md",
    "docs/regressionwright-flows.md",
    "docs/regressionwright-packaging.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "auth": "node bin/regressionwright.mjs auth",
    "check": "tsc --noEmit",
    "create": "node bin/create-regressionwright.mjs",
    "harness": "node bin/regressionwright.mjs",
    "regressionwright": "node bin/regressionwright.mjs",
    "pack:check": "node scripts/check-package.mjs",
    "profile": "node bin/regressionwright.mjs profile",
    "playwright:raw": "E2E_REGRESSION_DEV_FALLBACK=1 playwright test",
    "test": "pnpm test:unit",
    "test:unit": "playwright test tests/core tests/integrations",
    "verify": "pnpm check && pnpm test:unit && pnpm pack:check"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.60.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "dependencies": {
    "imapflow": "^1.3.5",
    "mailparser": "^3.9.9"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.0.0",
    "typescript": "~5.9.3"
  }
}
