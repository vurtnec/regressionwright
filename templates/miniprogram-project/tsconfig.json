{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true,
    "rootDir": ".",
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
